# Supabase project credentials (Project Settings → API in the Supabase dashboard).
# The anon key is safe to expose to the browser — Row Level Security policies
# (see supabase/migrations/0001_init.sql) enforce who can read/write what.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
